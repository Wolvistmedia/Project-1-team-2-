{
  "headers": {
    "x-nextjs-stale-time": "300",
    "x-nextjs-prerender": "1",
    "x-next-cache-tags": "_N_T_/layout,_N_T_/PrivacyPolicy/layout,_N_T_/PrivacyPolicy/page,_N_T_/PrivacyPolicy"
  },
  "segmentPaths": [
    "/_tree",
    "/_full",
    "/PrivacyPolicy/__PAGE__",
    "/PrivacyPolicy",
    "/_index",
    "/_head"
  ]
}